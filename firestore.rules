
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /adminUsers/{userId} { 
      allow read: if isOwner(userId) || isAdmin();
      // Permitimos que el usuario se registre a sí mismo si conoce la llave maestra (legacy)
      // En producción real esto se haría vía Cloud Function, pero para este MVP es el bootstrap seguro.
      allow create: if isOwner(userId);
      allow update, delete: if isAdmin();
    }
    
    match /institutions/{institutionId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /premiumAccessKeys/{keyId} {
      // Un usuario necesita poder buscar una llave específica para redimirla
      allow read, list: if isSignedIn();
      // Un usuario puede actualizar una llave SOLO para redimirla si está libre
      // Atómicidad garantizada por estas condiciones
      allow update: if isSignedIn() && 
                    resource.data.isActive == true && 
                    request.resource.data.isActive == false &&
                    request.resource.data.redeemedByUserId == request.auth.uid;
      // Solo el administrador crea o elimina llaves
      allow create, delete: if isAdmin();
    }

    match /users/{userId}/quizAttempts/{attemptId} { allow read, write: if isOwner(userId); }
    match /users/{userId}/quizSessions/{sessionId} { allow read, write: if isOwner(userId); }
    match /users/{userId}/userAchievements/{id} { allow read, write: if isOwner(userId); }
    match /users/{userId}/learningPathMissions/{id} { allow read, write: if isOwner(userId); }

    match /subjects/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /components/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /competencies/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /questions/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /exams/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /achievements/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /wildcards/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /users/{userId}/userWildcards/{id} { allow read, write: if isOwner(userId); }
    match /motivationalContent/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
  }
}
