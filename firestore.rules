
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a robust, multi-tier authorization model.
     * Enforces path-based ownership and allows for the 'Secret Key' admin escalation.
     */

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Permitimos que un usuario cree su propio registro de admin si es el dueño.
    // La validación real del código secreto se hace en la lógica del cliente para este MVP.
    match /adminUsers/{userId} { 
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update, delete: if isAdmin();
    }
    
    match /institutions/{institutionId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin());
    }

    // SUBCOLECCIONES DE RENDIMIENTO DEL USUARIO
    match /users/{userId}/quizAttempts/{attemptId} { allow read, write: if isOwner(userId); }
    match /users/{userId}/quizSessions/{sessionId} { allow read, write: if isOwner(userId); }
    match /users/{userId}/userAchievements/{id} { allow read: if isOwner(userId); allow write: if isOwner(userId); }
    match /users/{userId}/learningPathMissions/{id} { allow read, write: if isOwner(userId); }

    // CONTENIDO GLOBAL (ICFES)
    match /subjects/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /components/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /competencies/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /questions/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /exams/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /achievements/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
  }
}
