
{
  "entities": {
    "Institution": {
      "title": "Institution",
      "type": "object",
      "description": "Represents the institutional identity of the application.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "logoUrl", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "profileImageUrl": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "currentPoints": { "type": "number" },
        "isTrial": { "type": "boolean" },
        "trialEndDate": { "type": "string", "format": "date-time" },
        "institutionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "role", "currentPoints", "isTrial", "institutionId", "createdAt", "updatedAt"]
    },
    "PremiumAccessKey": {
      "title": "PremiumAccessKey",
      "type": "object",
      "description": "Represents a unique license key for access.",
      "properties": {
        "id": { "type": "string" },
        "keyString": { "type": "string" },
        "type": { "type": "string", "enum": ["premium_subscription", "admin_access"] },
        "durationDays": { "type": "number" },
        "redeemedByUserId": { "type": "string" },
        "redeemedAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "keyString", "type", "isActive", "createdAt"]
    },
    "Question": {
      "title": "Question",
      "type": "object",
      "description": "Represents a practice question.",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswerIndex": { "type": "number" },
        "explanation": { "type": "string" },
        "subjectId": { "type": "string" },
        "componentId": { "type": "string" },
        "competencyId": { "type": "string" },
        "level": { "type": "string" },
        "pointsAwarded": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "text", "options", "correctAnswerIndex", "explanation", "subjectId", "createdAt", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/institutions/{institutionId}": { "schema": "Institution", "description": "Global institutional data." },
    "/users/{userId}": { "schema": "User", "description": "User profile data." },
    "/adminUsers/{userId}": { "schema": "User", "description": "Admin privilege marker." },
    "/premiumAccessKeys/{keyId}": { "schema": "PremiumAccessKey", "description": "Unique license keys." },
    "/questions/{questionId}": { "schema": "Question", "description": "Practice questions database." }
  }
}
